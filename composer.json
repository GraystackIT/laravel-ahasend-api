{
    "name": "graystackit/laravel-ahasend-api",
    "description": "Laravel package for the Ahasend email API, powered by Saloon v4",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "GraystackIT",
            "email": "dev@graystack.it"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "saloonphp/saloon": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "GraystackIT\\Ahasend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraystackIT\\Ahasend\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GraystackIT\\Ahasend\\AhasendServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
